@using OpenLayers.Blazor

@namespace Ellipse.Components.Layout

<MudDrawerContainer Class="@_containerClass">
    <MudDrawer @bind-Open="Open"
               Anchor="Anchor.Left"
               Elevation="0"
               Variant="DrawerVariant.Persistent"
               Overlay="false"
               Style="transition: transform 0.4s ease, width 0.4s ease;"
               Width="400px"
               Height="100%"
               Class="border-r overflow-y-auto">

        <MudDrawerHeader
            Class="flex flex-col px-4 py-3 border-b gap-4">
            <div class="flex items-center justify-between w-full">
                <MudText Typo="Typo.h6" Class="font-bold text-gray-800">
                    Locations
                </MudText>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               @onclick="()=>ToggleOpen()"
                               Size="Size.Small"
                               Class="text-gray-400 hover:text-gray-600 transition-colors"/>
            </div>

            <div class="flex flex-col gap-2 w-full">
                <MudSelect T="SortBy" @bind-Value="_sortBy" Label="Sort By" Dense Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem Value="SortBy.None">None</MudSelectItem>
                    <MudSelectItem Value="SortBy.Distance">Distance</MudSelectItem>
                    <MudSelectItem Value="SortBy.Duration">Duration</MudSelectItem>
                </MudSelect>
            </div>
        </MudDrawerHeader>

        @if (_isList)
        {
            <div class="py-4">
                <Virtualize TItem="KeyValuePair<Coordinate, Marker>"
                            Context="kvp"
                            Items="@SortedMarkers">
                    <ItemContent>
                        @ListItem((kvp.Value.Text, kvp.Key,
                            kvp.Value.Properties["Routes"]["Average"].Distance,
                            kvp.Value.Properties["Routes"]["Average"].Duration))
                    </ItemContent>
                    <Placeholder>
                        <MudSkeleton Animation="Animation.Wave"
                                     SkeletonType="SkeletonType.Rectangle"
                                     Height="200px"/>
                    </Placeholder>
                </Virtualize>
            </div>
        }

        @if (!_isList && _selectedMarker != null)
        {
            <div class="fixed left-[400px] top-4 z-30 ml-4 transition-all duration-300 pointer-events-none">
                <MudPaper Elevation="6"
                          Class="p-0 w-[360px] rounded-lg overflow-hidden pointer-events-auto">
                    @SingleItem((_selectedMarker, _selectedMarker.Properties["Routes"]))
                </MudPaper>
            </div>
        }
    </MudDrawer>
</MudDrawerContainer>